{
  "name": "handex-handoff-express",
  "private": true,
  "version": "4.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "npm run bundle:code && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "refs:fetch": "node src/plugin/refs/fetch-design-refs.cjs",
    "refs:rebuild": "npm run refs:fetch && node src/plugin/refs/build-skeleton.cjs",
    "refs:update": "npm run refs:rebuild && npm run bundle:ui && npm run bundle:code",
    "bundle:refs": "node src/plugin/refs/build-skeleton.cjs",
    "bundle:css": "node node_modules/tw3/lib/cli.js --config src/plugin/styles/tailwind.config.cjs -i src/plugin/styles/tailwind-input.css -o src/plugin/styles/tailwind-compiled.css --minify",
    "bundle:ui": "npm run bundle:css && npm run bundle:refs && node src/plugin/build.cjs",
    "bundle:code": "node scripts/bundle-code.cjs",
    "export:plugin": "cp src/plugin/manifest.json handex-plugin/ && cp src/plugin/code.bundle.js handex-plugin/ && cp src/plugin/ui.html handex-plugin/ && echo '✅ handex-plugin/ atualizada'",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tw3": "npm:tailwindcss@^3.4.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
