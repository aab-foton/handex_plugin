{
  "version": "1.0.0",
  "description": "Mapeia bibliotecas Figma do DSC para pacotes/módulos no monorepo. Atualize conforme a estrutura de imports do código evoluir.",
  "libraries": {
    "Fundamentos Visuais": {
      "import": "@dsc/foundations",
      "language": "ts",
      "docs": "https://design.caixa/foundations",
      "notes": "Tokens base (cores, tipografia, espaçamento, sombras)."
    },
    "Super App": {
      "import": "@dsc/super-app",
      "language": "ts",
      "docs": "https://design.caixa/super-app",
      "notes": "Componentes React do Super App."
    },
    "Super Gerenciador": {
      "import": "@dsc/super-gerenciador",
      "language": "ts",
      "docs": "https://design.caixa/super-gerenciador",
      "notes": "Componentes React do Super Gerenciador."
    },
    "Web Angular & React": {
      "import": "@dsc/web",
      "subpaths": {
        "angular": "@dsc/web/angular",
        "react": "@dsc/web/react"
      },
      "language": "ts",
      "docs": "https://design.caixa/web",
      "notes": "Biblioteca dual-target. Use o subpath conforme stack do projeto."
    },
    "Design Acessível": {
      "import": "@dsc/a11y",
      "language": "ts",
      "docs": "https://design.caixa/a11y",
      "notes": "Utilitários e wrappers de acessibilidade."
    }
  },
  "componentOverrides": {}
}
